# ─────────────────────────────────────────────────────────────────────────────
# Enterprise AI Red Team Platform — Environment Configuration
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# Application
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# CORS (comma-separated origins, or * for all)
CORS_ORIGIN=http://localhost:5173

# ─── Auth ────────────────────────────────────────────────────────────────────
# REQUIRED: Generate with: openssl rand -hex 64
JWT_SECRET=change-me-to-a-long-random-secret-at-least-64-chars
JWT_EXPIRES_IN=7d

# ─── Database ────────────────────────────────────────────────────────────────
# SQLite (default, no setup needed):
DATABASE_URL=./data/eart.db

# Postgres (optional, uncomment and fill in):
# DATABASE_URL=postgresql://eart:yourpassword@localhost:5432/eart

# ─── Redis (BullMQ) ──────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Reports ─────────────────────────────────────────────────────────────────
REPORT_DIR=./data/reports

# ─── License ─────────────────────────────────────────────────────────────────
# Path to RSA public key for offline license validation
RSA_PUBLIC_KEY_PATH=./keys/license_public.pem

# ─── Email (optional, for scan completion notifications) ─────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
# Set to "true" for port 465 (SSL); leave unset for STARTTLS on port 587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@enterpriseairedteam.com

# Public URL used in email links (no trailing slash)
APP_URL=http://localhost:15500

# ─── Ollama (optional) ────────────────────────────────────────────────────────
# Override Ollama URL for Docker deployments. When unset, EART auto-detects
# Docker and rewrites localhost → host.docker.internal.
# OLLAMA_URL=http://host.docker.internal:11434

# Timeout in seconds for Ollama requests (default: 900 = 15 minutes).
# Increase for very slow models; decrease if you prefer faster failure.
# OLLAMA_TIMEOUT=900

# ─── Docker worker images ────────────────────────────────────────────────────
# These are the image names for Python tool runners
# Build with: docker compose --profile workers build
GARAK_IMAGE=eart-garak:latest
PYRIT_IMAGE=eart-pyrit:latest
DEEPTEAM_IMAGE=eart-deepteam:latest
