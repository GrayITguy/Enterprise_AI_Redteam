{
  "name": "enterpriseairedteam",
  "version": "1.0.0",
  "description": "Enterprise AI Red Team Platform - unified self-hosted security testing dashboard",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server/app.ts",
    "dev:worker": "tsx watch src/server/workers/scanWorker.ts",
    "build": "tsc -p tsconfig.json",
    "build:all": "npm run build && cd site && npm run build",
    "start": "node dist/server/app.js",
    "worker": "node dist/server/workers/scanWorker.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "license:keygen": "tsx scripts/keygen.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.7.0",
    "bullmq": "^5.70.1",
    "cors": "^2.8.5",
    "drizzle-orm": "^0.38.3",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "ioredis": "^5.6.0",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^3.0.3",
    "nodemailer": "^7.0.13",
    "pdfkit": "^0.16.0",
    "promptfoo": "^0.120.25",
    "uuid": "^11.1.0",
    "winston": "^3.17.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.12",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.13.0",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.23",
    "@types/pdfkit": "^0.13.8",
    "@types/uuid": "^10.0.0",
    "drizzle-kit": "^0.31.9",
    "tsx": "^4.19.0",
    "typescript": "^5.7.3"
  }
}
